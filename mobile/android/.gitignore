*.iml
.gradle
/local.properties
# Ignore IDE state broadly, but share project-level config that should be
# consistent across the team (e.g. inspection profile that disables the
# package-vs-directory check, since our Kotlin layout is intentionally flat).
/.idea/*
!/.idea/inspectionProfiles/
.DS_Store
# UniFFI build artifacts (regenerated by `make android-bindings`)
/Generated/
/app/src/main/jniLibs/
/build
/captures
.externalNativeBuild
.cxx
local.properties
# Release signing material must never be committed. `make android-release` pulls
# it from 1Password into a RAM disk at build time (nothing lands here), but these
# patterns are a safety net in case a keystore is ever copied in by hand.
*.jks
*.keystore
keystore.properties
