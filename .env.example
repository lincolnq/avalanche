# Add this to make your 'testbot' respond using AI instead of just echoing
ANTHROPIC_API_KEY=sk-ant-...

# The URL the homeserver advertises to clients (in DID docs and used to
# validate invite tokens — the token's server_url must match this exactly).
# Defaults to http://localhost:3000 if unset. To test from a phone on the
# same network, point this at a LAN IP, mDNS hostname, or Tailscale Magic
# DNS name. Examples:
#   SERVER_URL=http://192.168.1.42:3000
#   SERVER_URL=http://your-host.tailNNNNN.ts.net:3000
SERVER_URL=http://localhost:3000
