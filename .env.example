# Required for the 'testbot' to respond — it uses Claude and no longer echoes
# as a fallback, so it exits at startup if no key is set. You can instead set
# ANTHROPIC_AUTH_TOKEN (+ optional ANTHROPIC_BASE_URL / ANTHROPIC_MODEL).
ANTHROPIC_API_KEY=sk-ant-...

# The URL the homeserver advertises to clients (in DID docs and used to
# validate invite tokens — the token's server_url must match this exactly).
# Defaults to http://localhost:3000 if unset. To test from a phone on the
# same network, point this at a LAN IP, mDNS hostname, or Tailscale Magic
# DNS name. Examples:
#   SERVER_URL=http://192.168.1.42:3000
#   SERVER_URL=http://your-host.tailNNNNN.ts.net:3000
SERVER_URL=http://localhost:3000

# URL of the push relay the homeserver should notify when offline devices
# have pending messages. There is one single shared instance for dev + 
# production; you only need to set or unset this if developing against a 
# separate relay.
# RELAY_URL=http://localhost:3002
