{
  "name": "@theavalanche/app-core",
  "version": "0.4.0",
  "description": "Node.js bindings for Avalanche's app-core (encrypted messaging client).",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "license": "AGPL-3.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lincolnq/avalanche.git",
    "directory": "node/packages/app-core"
  },
  "homepage": "https://github.com/lincolnq/avalanche/tree/main/node/packages/app-core#readme",
  "bugs": "https://github.com/lincolnq/avalanche/issues",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist/",
    "native/index.js",
    "native/index.d.ts",
    "README.md",
    "LICENSE"
  ],
  "napi": {
    "name": "app-core",
    "triples": {
      "defaults": false,
      "additional": [
        "aarch64-apple-darwin",
        "x86_64-unknown-linux-gnu",
        "aarch64-unknown-linux-gnu"
      ]
    }
  },
  "scripts": {
    "build:native": "napi build --platform --release --cargo-cwd ../../../core/crates/app-core-node native",
    "build:native:debug": "napi build --platform --cargo-cwd ../../../core/crates/app-core-node native",
    "build:ts": "tsc",
    "build": "npm run build:native && npm run build:ts",
    "build:debug": "npm run build:native:debug && npm run build:ts",
    "docs": "typedoc",
    "smoke": "node smoke.mjs"
  },
  "dependencies": {
    "temporal-spec": "^0.3.1"
  },
  "optionalDependencies": {
    "@theavalanche/app-core-darwin-arm64": "0.4.0",
    "@theavalanche/app-core-linux-x64-gnu": "0.4.0",
    "@theavalanche/app-core-linux-arm64-gnu": "0.4.0"
  },
  "devDependencies": {
    "@napi-rs/cli": "^2.18.4",
    "@types/node": "^22.19.19",
    "typedoc": "^0.28.19",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=26"
  }
}
